rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // 2DID Mapping history.
    // 기존 Mapping app은 로그인 없이 GitHub Pages에서 바로 저장하는 구조입니다.
    // 운영용으로 잠글 때는 `if true`를 Auth 조건으로 변경하세요.
    match /mappingHistories/{historyId} {
      allow read, create, update, delete: if true;

      match /rowChunks/{chunkId} {
        allow read, create, update, delete: if true;
      }
    }

    // MTK Assy Yield raw data.
    match /yieldSummaryTapRaw/{docId} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && request.resource.data.keys().hasAll([
          'sod',
          'sckInputLotNo',
          'inQty',
          'dedupeKey',
          'uploadedAt'
        ])
        && request.resource.data.dedupeKey == docId;

      allow delete: if signedIn();
    }

    // MTK OS Comparison raw data.
    match /osComparisonRaw/{docId} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && request.resource.data.keys().hasAll([
          'inputDate',
          'lotId',
          'osInQty',
          'dedupeKey',
          'uploadedAt'
        ])
        && request.resource.data.dedupeKey == docId;

      allow delete: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
